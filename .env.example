# SPC Campus — environment variables
# Copy to `.env` for local use, or set these in the Render dashboard.

# ── Django core ───────────────────────────────────────────────
DJANGO_SECRET_KEY=change-me-to-a-long-random-string
DJANGO_DEBUG=true                       # set "false" in production
DJANGO_ALLOWED_HOSTS=localhost,127.0.0.1
DJANGO_CSRF_TRUSTED_ORIGINS=            # e.g. https://spc-campus.onrender.com
DJANGO_CORS_ALLOWED_ORIGINS=            # comma-separated extra origins for the API
DJANGO_SECURE_SSL_REDIRECT=true         # only enforced when DEBUG=false
DJANGO_HSTS_SECONDS=0                    # raise (e.g. 2592000) after HTTPS verified

# ── Database ──────────────────────────────────────────────────
# Leave unset locally to use SQLite. In production Render injects DATABASE_URL.
# DATABASE_URL=postgres://USER:PASSWORD@HOST:5432/DBNAME
DATABASE_SSL_REQUIRE=false              # "true" for managed Postgres

# ── Paystack (GHS payments) ──────────────────────────────────
PAYSTACK_SECRET_KEY=sk_test_xxx
PAYSTACK_PUBLIC_KEY=pk_test_xxx

# ── AI pipeline ───────────────────────────────────────────────
ANTHROPIC_API_KEY=sk-ant-xxx            # required for course generation
OPENAI_API_KEY=                         # optional — enables TTS audio
